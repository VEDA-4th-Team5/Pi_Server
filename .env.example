# Qt 조회 API: 인증서와 키를 모두 비우면 개발용 HTTP로 동작한다.
HTTP_API_ENABLED=true
HTTP_LISTEN_ADDRESS=0.0.0.0
HTTP_PORT=8080
HTTP_TLS_CERT_PATH=
HTTP_TLS_KEY_PATH=
HTTP_DATA_ROOT=data
HTTP_MAX_IMAGE_MB=10

EVENT_DB_PATH=data/db/parking.db
MQTT_HOST=localhost
MQTT_PORT=1883
CAMERA_RTSP=
GEMINI_API_KEY=

# 실제 UART 연결 전 개발용 홀센서 MQTT 입력
HALL_MQTT_INPUT_ENABLED=true
HALL_MQTT_TOPIC=parking/sensor/hall
PARKING_SLOT_CONFIG=config/parking_slots.json

# 실제 STM32/LoRa 직렬 입력. off | uart-line | lora-frame
# uart-line: SENSOR:HALL01:OCCUPIED:1\n 텍스트
# lora-frame: docs/UART_LORA_PROTOCOL.md의 CRC16 binary frame
SENSOR_LINK_MODE=off
SENSOR_UART_DEVICE=/dev/ttyAMA0
SENSOR_UART_BAUD=115200
SENSOR_UART_READ_TIMEOUT_MS=250
SENSOR_UART_RECONNECT_MS=1000

# pi-server 내부 EV/PHEV 장기 점유 타이머
PARKING_TIMER_ENABLED=true
PARKING_TIMEOUT_SECONDS=3600
